# CommerceFlow environment template
# Copy to apps/api/.env for local API development (or export in your process manager).
# Do not commit real secrets.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# Node environment: development | test | production
NODE_ENV=development

# HTTP port for the API process (Next.js uses this when started with PORT)
PORT=3000

# Public application / API base URL (used by deployment HTTPS checks)
APP_URL=http://localhost:3000

# Optional explicit public API URL (preferred for HTTPS readiness checks)
PUBLIC_API_URL=http://localhost:3000

# Structured logging preference (platform observability configuration may override)
LOG_LEVEL=info

# Optional build identifier reported by release metadata diagnostics
BUILD_ID=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string for Prisma (required for persisted repositories)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/commerceflow?schema=public

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------

# Required at runtime: signs access and refresh tokens (AUTH_JWT_SECRET)
AUTH_JWT_SECRET=change-me-in-production

# Alias documented for operators familiar with JWT_SECRET naming.
# CommerceFlow currently reads AUTH_JWT_SECRET only for token signing.
# JWT_SECRET=

# Access / refresh token TTLs are defined in code (15m / 7d).
# JWT_EXPIRES_IN is reserved for documentation parity and is not read at runtime.
# JWT_EXPIRES_IN=15m

# Required by deployment / security diagnostics (set in production even if
# auth currently signs with AUTH_JWT_SECRET alone):
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# -----------------------------------------------------------------------------
# API keys
# -----------------------------------------------------------------------------

# API keys are hashed at rest; no separate pepper is required today.
# Reserved for future key-derivation hardening:
# API_KEY_SECRET=

# -----------------------------------------------------------------------------
# Clients (optional local development)
# -----------------------------------------------------------------------------

# Admin (Next.js)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Mobile (Expo)
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
