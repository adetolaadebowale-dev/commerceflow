# CommerceFlow environment template
# Copy to apps/api/.env for local API development (or export in your process manager).
# Do not commit real secrets.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# Node environment: development | test | production
NODE_ENV=development

# HTTP port for the API process (Next.js uses this when started with PORT)
PORT=3000

# Public application / API base URL (used by deployment HTTPS checks)
APP_URL=http://localhost:3000

# Optional explicit public API URL (preferred for HTTPS readiness checks)
PUBLIC_API_URL=http://localhost:3000

# Structured logging preference (platform observability configuration may override)
LOG_LEVEL=info

# Optional build identifier reported by release metadata diagnostics
BUILD_ID=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string for Prisma (required for persisted repositories)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/commerceflow?schema=public

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------

# Required at runtime: signs access and refresh tokens.
# The API fails fast on startup if this is missing or empty.
# Do not use documented placeholders (e.g. change-me-in-production) in production.
AUTH_JWT_SECRET=replace-with-a-long-random-secret

# Access / refresh token TTLs are defined in code (15m / 7d).
# JWT_EXPIRES_IN is reserved for documentation parity and is not read at runtime.
# JWT_EXPIRES_IN=15m

# -----------------------------------------------------------------------------
# API keys
# -----------------------------------------------------------------------------

# API keys are hashed at rest; no separate pepper is required today.
# Reserved for future key-derivation hardening:
# API_KEY_SECRET=

# -----------------------------------------------------------------------------
# Clients (optional local development)
# -----------------------------------------------------------------------------

# Comma-separated browser origins allowed to call the API (Admin on :3001).
# Defaults in non-production: http://localhost:3001,http://127.0.0.1:3001
# CORS_ALLOWED_ORIGINS=http://localhost:3001

# Admin (Next.js) — copy apps/admin/.env.example → apps/admin/.env.local
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
# Seeded store id from `pnpm --filter api db:seed` (admin@commerceflow.local / Password123!)
# NEXT_PUBLIC_DEFAULT_STORE_ID=11111111-1111-1111-1111-111111111111

# Mobile (Expo)
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Product media storage (local development)
# -----------------------------------------------------------------------------

# Filesystem root for LocalStorageProvider (defaults to <repo>/.tmp/media).
# Keep this outside the git working tree.
# MEDIA_STORAGE_PATH=

# Public URL prefix returned as ProductMedia.url (defaults to PUBLIC_API_URL/media).
# MEDIA_PUBLIC_BASE_URL=http://localhost:3000/media

# Storage provider: local (default) | memory (tests)
# MEDIA_STORAGE_PROVIDER=local
