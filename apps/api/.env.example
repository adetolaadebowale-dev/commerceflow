# PostgreSQL connection string for Prisma (required in production/dev with Prisma repositories).
# When unset, the API falls back to in-memory repositories (used by Vitest).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/commerceflow?schema=public"

# Required: JWT signing secret for access and refresh tokens.
# The API fails to start if this is missing or empty.
# Do not use documented placeholders in production.
AUTH_JWT_SECRET="replace-with-a-long-random-secret"

# Optional runtime / readiness settings.
NODE_ENV=development
PORT=3000
APP_URL="http://localhost:3000"
PUBLIC_API_URL="http://localhost:3000"
LOG_LEVEL=info
BUILD_ID=

# Browser origins for Admin Dashboard (defaults to localhost:3001 in development).
# CORS_ALLOWED_ORIGINS=http://localhost:3001

# Canonical template with full comments: ../../.env.example

# Local product media storage (outside the repo by default when unset).
# MEDIA_STORAGE_PATH=C:\Projects\commerceflow\.tmp\media
# MEDIA_PUBLIC_BASE_URL=http://localhost:3000/media
# MEDIA_STORAGE_PROVIDER=local
