# PostgreSQL connection string for Prisma (required in production/dev with Prisma repositories).
# When unset, the API falls back to in-memory repositories (used by Vitest).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/commerceflow?schema=public"

# JWT signing secret for access and refresh tokens (required at runtime).
AUTH_JWT_SECRET="change-me-in-production"

# Required by deployment / security diagnostics.
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Optional runtime / readiness settings.
NODE_ENV=development
PORT=3000
APP_URL="http://localhost:3000"
PUBLIC_API_URL="http://localhost:3000"
LOG_LEVEL=info
BUILD_ID=

# Canonical template with full comments: ../../.env.example
