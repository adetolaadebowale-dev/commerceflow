{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "node --experimental-strip-types prisma/seed.ts"
  },
  "dependencies": {
    "@commerceflow/api-client": "workspace:*",
    "@commerceflow/types": "workspace:*",
    "@commerceflow/validation": "workspace:*",
    "@prisma/client": "^6.19.0",
    "jose": "^6.2.3",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@commerceflow/config": "workspace:*",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^8.57.1",
    "eslint-config-next": "16.2.10",
    "prisma": "^6.19.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
