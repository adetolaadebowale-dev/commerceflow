// CommerceFlow production schema — Identity and Organization domains.
// User/Session fields align with @commerceflow/types contracts.
// Organization models are persistence-only until shared contracts are introduced.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Mirrors UserRole from @commerceflow/types — do not add values without updating shared contracts.
enum UserRole {
  customer
  staff
  admin
  super_admin
}

enum SessionStatus {
  active
  revoked
  expired
}

enum StoreRole {
  owner
  admin
  manager
  staff
}

/// Mirrors ProductStatus from @commerceflow/types.
enum ProductStatus {
  draft
  active
  archived
}

/// Mirrors StockMovementReason from @commerceflow/types.
enum StockMovementReason {
  initial
  manual_adjustment
  sale_reserved_ready
  sale_fulfilled
}

/// Mirrors OrderStatus from @commerceflow/types.
enum OrderStatus {
  draft
  confirmed
  cancelled
  fulfilled
}

/// Mirrors ReservationStatus from @commerceflow/types.
enum ReservationStatus {
  active
  released
  fulfilled
}

/// Mirrors CustomerStatus from @commerceflow/types.
enum CustomerStatus {
  active
  inactive
}

/// Mirrors CartStatus from @commerceflow/types.
enum CartStatus {
  active
  converted
  abandoned
}

/// Mirrors PaymentStatus from @commerceflow/types.
enum PaymentStatus {
  pending
  authorized
  paid
  failed
  cancelled
}

/// Mirrors PaymentProvider from @commerceflow/types.
enum PaymentProvider {
  internal
  manual
}

/// Mirrors InvoiceStatus from @commerceflow/types.
enum InvoiceStatus {
  draft
  issued
  paid
  void
}

/// Mirrors RefundStatus from @commerceflow/types.
enum RefundStatus {
  pending
  completed
  cancelled
}

/// Mirrors PromotionType from @commerceflow/types.
enum PromotionType {
  percentage
  fixed_amount
}

/// Mirrors PromotionStatus from @commerceflow/types.
enum PromotionStatus {
  draft
  active
  inactive
  expired
}

/// Mirrors TaxRateStatus from @commerceflow/types.
enum TaxRateStatus {
  active
  inactive
}

/// Mirrors ShipmentStatus from @commerceflow/types.
enum ShipmentStatus {
  pending
  packed
  shipped
  delivered
  cancelled
}

/// Mirrors ShipmentCarrier from @commerceflow/types.
enum ShipmentCarrier {
  internal
  manual
}

/// Mirrors ShipmentTrackingEventType from @commerceflow/types.
enum ShipmentTrackingEventType {
  status_update
  location_update
  carrier_update
  delivery_attempt
  note
  exception
}

/// Mirrors WeightUnit from @commerceflow/types.
enum WeightUnit {
  kg
  lb
  g
  oz
}

/// Mirrors DimensionUnit from @commerceflow/types.
enum DimensionUnit {
  cm
  in
  m
}

/// Mirrors ShippingZoneStatus from @commerceflow/types.
enum ShippingZoneStatus {
  active
  inactive
}

/// Mirrors ShippingMethodStatus from @commerceflow/types.
enum ShippingMethodStatus {
  active
  inactive
}

/// Persists User contract fields plus passwordHash (API-internal).
model User {
  id              String        @id @default(uuid()) @db.Uuid
  email           String        @unique
  emailVerified   Boolean       @default(false) @map("email_verified")
  firstName       String        @map("first_name")
  lastName        String        @map("last_name")
  role            UserRole      @default(customer)
  passwordHash    String        @map("password_hash")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")
  sessions        Session[]
  storeMemberships StoreMember[]
  orders          Order[]
  auditLogs       AuditLog[]

  @@index([deletedAt])
  @@map("users")
}

/// Persists Session contract fields plus refreshTokenId and status (API-internal).
model Session {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         SessionStatus @default(active)
  expiresAt      DateTime      @map("expires_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  lastActiveAt   DateTime      @map("last_active_at")
  ipAddress      String?       @map("ip_address")
  userAgent      String?       @map("user_agent")
  refreshTokenId String        @map("refresh_token_id")
  auditLogs      AuditLog[]

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("sessions")
}

/// Tenant boundary for multi-store commerce operations.
model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  stores    Store[]

  @@index([deletedAt])
  @@map("organizations")
}

/// Physical or logical storefront belonging to an organization.
model Store {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  name           String
  slug           String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  members        StoreMember[]
  brands         Brand[]
  categories     Category[]
  products       Product[]
  productVariants ProductVariant[]
  inventoryItems InventoryItem[]
  stockMovements StockMovement[]
  orders         Order[]
  inventoryReservations InventoryReservation[]
  auditLogs             AuditLog[]
  customers             Customer[]
  customerAddresses     CustomerAddress[]
  carts                 Cart[]
  payments              Payment[]
  invoices              Invoice[]
  refunds               Refund[]
  promotions            Promotion[]
  taxRates              TaxRate[]
  cartPromotions        CartPromotion[]
  orderAppliedPromotions OrderAppliedPromotion[]
  orderAppliedTaxRates  OrderAppliedTaxRate[]
  orderAppliedShippingMethods OrderAppliedShippingMethod[]
  shipments             Shipment[]
  shipmentTrackingEvents ShipmentTrackingEvent[]
  shipmentPackages       ShipmentPackage[]
  shippingZones          ShippingZone[]
  shippingMethods        ShippingMethod[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("stores")
}

/// Links a user to a store with a store-scoped role.
model StoreMember {
  id        String     @id @default(uuid()) @db.Uuid
  storeId   String     @map("store_id") @db.Uuid
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId    String     @map("user_id") @db.Uuid
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      StoreRole
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")

  @@unique([storeId, userId])
  @@index([userId])
  @@index([deletedAt])
  @@map("store_members")
}

/// Product brand used for catalog merchandising.
model Brand {
  id          String    @id @default(uuid()) @db.Uuid
  storeId     String    @map("store_id") @db.Uuid
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name        String
  slug        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  products    Product[]

  @@index([storeId])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("brands")
}

/// Product category within the catalog hierarchy.
model Category {
  id          String     @id @default(uuid()) @db.Uuid
  storeId     String     @map("store_id") @db.Uuid
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name        String
  slug        String
  description String?
  parentId    String?    @map("parent_id") @db.Uuid
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")
  products    Product[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([parentId])
  @@index([storeId, parentId])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("categories")
}

/// Catalog product with one or more purchasable variants.
model Product {
  id          String           @id @default(uuid()) @db.Uuid
  storeId     String           @map("store_id") @db.Uuid
  store       Store            @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name        String
  slug        String
  description String?
  status      ProductStatus    @default(draft)
  categoryId  String           @map("category_id") @db.Uuid
  category    Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brandId     String?          @map("brand_id") @db.Uuid
  brand       Brand?           @relation(fields: [brandId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  variants    ProductVariant[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([storeId, categoryId])
  @@index([storeId, status])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("products")
}

/// Purchasable SKU belonging to a product.
model ProductVariant {
  id         String   @id @default(uuid()) @db.Uuid
  storeId    String   @map("store_id") @db.Uuid
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  productId  String   @map("product_id") @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku        String
  name       String
  price      Decimal  @db.Decimal(12, 2)
  currency   String   @db.Char(3)
  attributes Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  inventoryItem InventoryItem?
  orderItems OrderItem[]
  cartItems  CartItem[]

  @@unique([storeId, sku])
  @@index([storeId])
  @@index([productId])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("product_variants")
}

/// Current on-hand stock for a product variant within a store.
model InventoryItem {
  id               String          @id @default(uuid()) @db.Uuid
  storeId          String          @map("store_id") @db.Uuid
  store            Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  productVariantId String          @unique @map("product_variant_id") @db.Uuid
  productVariant   ProductVariant  @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  quantityOnHand   Int             @map("quantity_on_hand")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")
  stockMovements   StockMovement[]
  inventoryReservations InventoryReservation[]

  @@unique([storeId, productVariantId])
  @@index([storeId])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("inventory_items")
}

/// Immutable ledger entry for an inventory quantity change.
model StockMovement {
  id               String              @id @default(uuid()) @db.Uuid
  storeId          String              @map("store_id") @db.Uuid
  store            Store               @relation(fields: [storeId], references: [id], onDelete: Restrict)
  inventoryItemId  String              @map("inventory_item_id") @db.Uuid
  inventoryItem    InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  productVariantId String              @map("product_variant_id") @db.Uuid
  quantityChange   Int                 @map("quantity_change")
  quantityAfter    Int                 @map("quantity_after")
  reason           StockMovementReason
  createdAt        DateTime            @default(now()) @map("created_at")

  @@index([storeId])
  @@index([inventoryItemId])
  @@index([productVariantId])
  @@index([storeId, inventoryItemId])
  @@index([storeId, productVariantId])
  @@index([createdAt])
  @@map("stock_movements")
}

/// Store-scoped customer order with snapshotted line items.
model Order {
  id          String      @id @default(uuid()) @db.Uuid
  storeId     String      @map("store_id") @db.Uuid
  store       Store       @relation(fields: [storeId], references: [id], onDelete: Restrict)
  customerId  String?     @map("customer_id") @db.Uuid
  customer    User?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerProfileId String? @map("customer_profile_id") @db.Uuid
  customerProfile     Customer? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  sourceCartId        String? @map("source_cart_id") @db.Uuid
  sourceCart          Cart?   @relation(fields: [sourceCartId], references: [id], onDelete: SetNull)
  orderNumber String      @map("order_number")
  status      OrderStatus @default(draft)
  subtotal    Decimal     @db.Decimal(12, 2)
  discountAmount Decimal? @map("discount_amount") @db.Decimal(12, 2)
  taxAmount   Decimal?    @map("tax_amount") @db.Decimal(12, 2)
  shippingAmount Decimal? @map("shipping_amount") @db.Decimal(12, 2)
  total       Decimal     @db.Decimal(12, 2)
  currency    String      @db.Char(3)
  shippingRecipientName  String? @map("shipping_recipient_name")
  shippingPhone          String? @map("shipping_phone")
  shippingAddressLine1   String? @map("shipping_address_line1")
  shippingAddressLine2   String? @map("shipping_address_line2")
  shippingCity           String? @map("shipping_city")
  shippingStateProvince  String? @map("shipping_state_province")
  shippingPostalCode     String? @map("shipping_postal_code")
  shippingCountryCode    String? @map("shipping_country_code") @db.Char(2)
  confirmedAt DateTime?   @map("confirmed_at")
  cancelledAt DateTime?   @map("cancelled_at")
  fulfilledAt DateTime?   @map("fulfilled_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  items       OrderItem[]
  inventoryReservations InventoryReservation[]
  payments    Payment[]
  invoices    Invoice[]
  appliedPromotion OrderAppliedPromotion?
  appliedTaxRate   OrderAppliedTaxRate?
  appliedShippingMethod OrderAppliedShippingMethod?
  shipments        Shipment[]

  @@unique([storeId, orderNumber])
  @@index([storeId])
  @@index([status])
  @@index([storeId, status])
  @@index([customerId])
  @@index([customerProfileId])
  @@index([sourceCartId])
  @@index([createdAt])
  @@index([storeId, createdAt])
  @@map("orders")
}

/// Line item belonging to an order with immutable product snapshot fields.
model OrderItem {
  id               String         @id @default(uuid()) @db.Uuid
  orderId          String         @map("order_id") @db.Uuid
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariantId String         @map("product_variant_id") @db.Uuid
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  productName      String         @map("product_name")
  sku              String
  unitPrice        Decimal        @map("unit_price") @db.Decimal(12, 2)
  currency         String         @db.Char(3)
  quantity         Int
  lineSubtotal     Decimal        @map("line_subtotal") @db.Decimal(12, 2)
  createdAt        DateTime       @default(now()) @map("created_at")
  inventoryReservation InventoryReservation?

  @@index([orderId])
  @@index([productVariantId])
  @@map("order_items")
}

/// Soft reservation of on-hand stock for a confirmed order line item.
model InventoryReservation {
  id               String            @id @default(uuid()) @db.Uuid
  storeId          String            @map("store_id") @db.Uuid
  store            Store             @relation(fields: [storeId], references: [id], onDelete: Restrict)
  orderId          String            @map("order_id") @db.Uuid
  order            Order             @relation(fields: [orderId], references: [id], onDelete: Restrict)
  orderItemId      String            @unique @map("order_item_id") @db.Uuid
  orderItem        OrderItem         @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  inventoryItemId  String            @map("inventory_item_id") @db.Uuid
  inventoryItem    InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  reservedQuantity Int               @map("reserved_quantity")
  status           ReservationStatus @default(active)
  createdAt        DateTime          @default(now()) @map("created_at")
  releasedAt       DateTime?         @map("released_at")
  fulfilledAt      DateTime?         @map("fulfilled_at")

  @@index([storeId])
  @@index([orderId])
  @@index([inventoryItemId])
  @@index([storeId, orderId])
  @@index([storeId, inventoryItemId, status])
  @@index([status])
  @@map("inventory_reservations")
}

/// Internal payment record linked to an order.
model Payment {
  id        String          @id @default(uuid()) @db.Uuid
  storeId   String          @map("store_id") @db.Uuid
  store     Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  orderId   String          @map("order_id") @db.Uuid
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Restrict)
  amount    Decimal         @db.Decimal(12, 2)
  currency  String          @db.Char(3)
  status    PaymentStatus   @default(pending)
  provider  PaymentProvider @default(internal)
  reference String
  metadata  Json?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@unique([storeId, reference])
  @@index([storeId])
  @@index([orderId])
  @@index([storeId, orderId])
  @@index([status])
  @@index([storeId, status])
  @@map("payments")
  refunds   Refund[]
}

/// Financial invoice document linked to an order.
model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  storeId       String        @map("store_id") @db.Uuid
  store         Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  orderId       String        @map("order_id") @db.Uuid
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  invoiceNumber String        @map("invoice_number")
  status        InvoiceStatus @default(draft)
  subtotal       Decimal       @db.Decimal(12, 2)
  discountAmount Decimal?      @map("discount_amount") @db.Decimal(12, 2)
  taxAmount      Decimal?      @map("tax_amount") @db.Decimal(12, 2)
  taxRateId           String?   @map("tax_rate_id") @db.Uuid
  taxRateNameSnapshot String?   @map("tax_rate_name_snapshot")
  taxRatePercentageSnapshot Decimal? @map("tax_rate_percentage_snapshot") @db.Decimal(5, 2)
  shippingAmount Decimal?      @map("shipping_amount") @db.Decimal(12, 2)
  shippingMethodId        String?          @map("shipping_method_id") @db.Uuid
  shippingZoneId          String?          @map("shipping_zone_id") @db.Uuid
  shippingMethodNameSnapshot String?       @map("shipping_method_name_snapshot")
  shippingZoneNameSnapshot   String?       @map("shipping_zone_name_snapshot")
  shippingCarrierSnapshot    ShipmentCarrier? @map("shipping_carrier_snapshot")
  shippingFlatRateSnapshot   Decimal?      @map("shipping_flat_rate_snapshot") @db.Decimal(12, 2)
  shippingCurrencySnapshot   String?       @map("shipping_currency_snapshot") @db.Char(3)
  total          Decimal       @db.Decimal(12, 2)
  currency       String        @db.Char(3)
  issuedAt      DateTime?     @map("issued_at")
  dueAt         DateTime?     @map("due_at")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@unique([storeId, invoiceNumber])
  @@unique([storeId, orderId])
  @@index([storeId])
  @@index([orderId])
  @@index([storeId, orderId])
  @@index([status])
  @@index([storeId, status])
  @@map("invoices")
}

/// Full refund record linked to a payment.
model Refund {
  id          String       @id @default(uuid()) @db.Uuid
  storeId     String       @map("store_id") @db.Uuid
  store       Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  paymentId   String       @map("payment_id") @db.Uuid
  payment     Payment      @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  amount      Decimal      @db.Decimal(12, 2)
  currency    String       @db.Char(3)
  status      RefundStatus @default(pending)
  reason      String
  completedAt DateTime?    @map("completed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@unique([storeId, paymentId])
  @@index([storeId])
  @@index([paymentId])
  @@index([storeId, paymentId])
  @@index([status])
  @@index([storeId, status])
  @@map("refunds")
}

/// Merchant-managed discount promotion.
model Promotion {
  id          String           @id @default(uuid()) @db.Uuid
  storeId     String           @map("store_id") @db.Uuid
  store       Store            @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name        String
  code        String
  description String?
  type        PromotionType
  value       Decimal          @db.Decimal(12, 2)
  currency    String?          @db.Char(3)
  status      PromotionStatus  @default(draft)
  startsAt    DateTime         @map("starts_at")
  endsAt      DateTime         @map("ends_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  cartPromotions CartPromotion[]
  orderAppliedPromotions OrderAppliedPromotion[]

  @@index([storeId])
  @@index([status])
  @@index([storeId, status])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("promotions")
}

/// Store-scoped tax rate configuration.
model TaxRate {
  id          String        @id @default(uuid()) @db.Uuid
  storeId     String        @map("store_id") @db.Uuid
  store       Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name        String
  percentage  Decimal       @db.Decimal(5, 2)
  status      TaxRateStatus @default(inactive)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")
  orderAppliedTaxRates OrderAppliedTaxRate[]

  @@index([storeId])
  @@index([status])
  @@index([storeId, status])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("tax_rates")
}

/// Immutable append-only record of authenticated administrative actions.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  storeId    String?  @map("store_id") @db.Uuid
  store      Store?   @relation(fields: [storeId], references: [id], onDelete: Restrict)
  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  sessionId  String   @map("session_id") @db.Uuid
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid
  action     String
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([storeId])
  @@index([userId])
  @@index([sessionId])
  @@index([entityType, entityId])
  @@index([storeId, createdAt])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Store-scoped customer profile independent of platform User identity.
model Customer {
  id        String         @id @default(uuid()) @db.Uuid
  storeId   String         @map("store_id") @db.Uuid
  store     Store          @relation(fields: [storeId], references: [id], onDelete: Restrict)
  email     String
  firstName String         @map("first_name")
  lastName  String         @map("last_name")
  phone     String?
  status    CustomerStatus @default(active)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  deletedAt DateTime?      @map("deleted_at")
  addresses CustomerAddress[]
  carts     Cart[]
  orders    Order[]

  @@index([storeId])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@index([storeId, status])
  @@map("customers")
}

/// Store-scoped postal address belonging to a customer profile.
model CustomerAddress {
  id             String   @id @default(uuid()) @db.Uuid
  customerId     String   @map("customer_id") @db.Uuid
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  storeId        String   @map("store_id") @db.Uuid
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  label          String
  recipientName  String   @map("recipient_name")
  phone          String?
  addressLine1   String   @map("address_line1")
  addressLine2   String?  @map("address_line2")
  city           String
  stateProvince  String   @map("state_province")
  postalCode     String   @map("postal_code")
  countryCode    String   @map("country_code") @db.Char(2)
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  @@index([customerId])
  @@index([storeId])
  @@index([storeId, customerId])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("customer_addresses")
}

/// Store-scoped mutable shopping cart belonging to a customer.
model Cart {
  id         String     @id @default(uuid()) @db.Uuid
  storeId    String     @map("store_id") @db.Uuid
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Restrict)
  customerId String     @map("customer_id") @db.Uuid
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status     CartStatus @default(active)
  subtotal   Decimal    @default(0) @db.Decimal(12, 2)
  currency   String     @default("USD") @db.Char(3)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  items      CartItem[]
  orders     Order[]
  promotion  CartPromotion?

  @@index([storeId])
  @@index([customerId])
  @@index([storeId, customerId])
  @@index([status])
  @@index([storeId, status])
  @@map("carts")
}

/// Mutable cart line with snapshotted pricing at add time.
model CartItem {
  id                String         @id @default(uuid()) @db.Uuid
  cartId            String         @map("cart_id") @db.Uuid
  cart              Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productVariantId  String         @map("product_variant_id") @db.Uuid
  productVariant    ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  quantity          Int
  unitPriceSnapshot Decimal        @map("unit_price_snapshot") @db.Decimal(12, 2)
  currencySnapshot  String         @map("currency_snapshot") @db.Char(3)
  lineSubtotal      Decimal        @map("line_subtotal") @db.Decimal(12, 2)
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  @@unique([cartId, productVariantId])
  @@index([cartId])
  @@index([productVariantId])
  @@map("cart_items")
}

/// Applied promotion linked to an active shopping cart.
model CartPromotion {
  id                      String        @id @default(uuid()) @db.Uuid
  storeId                 String        @map("store_id") @db.Uuid
  store                   Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  cartId                  String        @unique @map("cart_id") @db.Uuid
  cart                    Cart          @relation(fields: [cartId], references: [id], onDelete: Cascade)
  promotionId             String        @map("promotion_id") @db.Uuid
  promotion               Promotion     @relation(fields: [promotionId], references: [id], onDelete: Restrict)
  promotionCodeSnapshot   String        @map("promotion_code_snapshot")
  promotionTypeSnapshot   PromotionType @map("promotion_type_snapshot")
  promotionValueSnapshot  Decimal       @map("promotion_value_snapshot") @db.Decimal(12, 2)
  discountAmount          Decimal       @map("discount_amount") @db.Decimal(12, 2)
  createdAt               DateTime      @default(now()) @map("created_at")

  @@index([storeId])
  @@index([cartId])
  @@index([promotionId])
  @@index([storeId, cartId])
  @@map("cart_promotions")
}

/// Immutable promotion snapshot captured on an order at checkout.
model OrderAppliedPromotion {
  id                      String        @id @default(uuid()) @db.Uuid
  storeId                 String        @map("store_id") @db.Uuid
  store                   Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  orderId                 String        @unique @map("order_id") @db.Uuid
  order                   Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  promotionId             String        @map("promotion_id") @db.Uuid
  promotion               Promotion     @relation(fields: [promotionId], references: [id], onDelete: Restrict)
  promotionCodeSnapshot   String        @map("promotion_code_snapshot")
  promotionTypeSnapshot   PromotionType @map("promotion_type_snapshot")
  promotionValueSnapshot  Decimal       @map("promotion_value_snapshot") @db.Decimal(12, 2)
  discountAmount          Decimal       @map("discount_amount") @db.Decimal(12, 2)
  createdAt               DateTime      @default(now()) @map("created_at")

  @@index([storeId])
  @@index([orderId])
  @@index([promotionId])
  @@map("order_applied_promotions")
}

model OrderAppliedTaxRate {
  id                   String   @id @default(uuid()) @db.Uuid
  storeId              String   @map("store_id") @db.Uuid
  store                Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  orderId              String   @unique @map("order_id") @db.Uuid
  order                Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  taxRateId            String   @map("tax_rate_id") @db.Uuid
  taxRate              TaxRate  @relation(fields: [taxRateId], references: [id], onDelete: Restrict)
  nameSnapshot         String   @map("name_snapshot")
  percentageSnapshot   Decimal  @map("percentage_snapshot") @db.Decimal(5, 2)
  taxAmount            Decimal  @map("tax_amount") @db.Decimal(12, 2)
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([storeId])
  @@index([orderId])
  @@index([taxRateId])
  @@map("order_applied_tax_rates")
}

/// Immutable shipping method snapshot captured on an order at checkout.
model OrderAppliedShippingMethod {
  id                  String          @id @default(uuid()) @db.Uuid
  storeId             String          @map("store_id") @db.Uuid
  store               Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  orderId             String          @unique @map("order_id") @db.Uuid
  order               Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shippingMethodId    String          @map("shipping_method_id") @db.Uuid
  shippingMethod      ShippingMethod  @relation(fields: [shippingMethodId], references: [id], onDelete: Restrict)
  shippingZoneId      String          @map("shipping_zone_id") @db.Uuid
  shippingZone        ShippingZone    @relation(fields: [shippingZoneId], references: [id], onDelete: Restrict)
  methodNameSnapshot  String          @map("method_name_snapshot")
  zoneNameSnapshot    String          @map("zone_name_snapshot")
  carrierSnapshot     ShipmentCarrier @map("carrier_snapshot")
  flatRateSnapshot    Decimal         @map("flat_rate_snapshot") @db.Decimal(12, 2)
  currencySnapshot    String          @map("currency_snapshot") @db.Char(3)
  shippingAmount      Decimal         @map("shipping_amount") @db.Decimal(12, 2)
  createdAt           DateTime        @default(now()) @map("created_at")

  @@index([storeId])
  @@index([orderId])
  @@index([shippingMethodId])
  @@index([shippingZoneId])
  @@map("order_applied_shipping_methods")
}

/// Store-scoped shipment linked to a fulfilled order with snapshotted shipping address.
model Shipment {
  id                     String          @id @default(uuid()) @db.Uuid
  storeId                String          @map("store_id") @db.Uuid
  store                  Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  orderId                String          @map("order_id") @db.Uuid
  order                  Order           @relation(fields: [orderId], references: [id], onDelete: Restrict)
  shipmentNumber         String          @map("shipment_number")
  carrier                ShipmentCarrier
  trackingNumber         String?         @map("tracking_number")
  shippingRecipientName  String          @map("shipping_recipient_name")
  shippingPhone          String          @map("shipping_phone")
  shippingAddressLine1   String          @map("shipping_address_line1")
  shippingAddressLine2   String?         @map("shipping_address_line2")
  shippingCity           String          @map("shipping_city")
  shippingStateProvince  String          @map("shipping_state_province")
  shippingPostalCode     String          @map("shipping_postal_code")
  shippingCountryCode    String          @map("shipping_country_code") @db.Char(2)
  status                 ShipmentStatus  @default(pending)
  shippedAt              DateTime?       @map("shipped_at")
  deliveredAt            DateTime?       @map("delivered_at")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")
  trackingEvents         ShipmentTrackingEvent[]
  packages               ShipmentPackage[]

  @@unique([storeId, shipmentNumber])
  @@unique([storeId, orderId])
  @@index([storeId])
  @@index([orderId])
  @@index([storeId, orderId])
  @@index([status])
  @@index([storeId, status])
  @@map("shipments")
}

/// Physical package belonging to a shipment with warehouse dimensions and optional tracking.
model ShipmentPackage {
  id             String         @id @default(uuid()) @db.Uuid
  shipmentId     String         @map("shipment_id") @db.Uuid
  shipment       Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  storeId        String         @map("store_id") @db.Uuid
  store          Store          @relation(fields: [storeId], references: [id], onDelete: Restrict)
  packageNumber  String         @map("package_number")
  weight         Decimal        @db.Decimal(12, 3)
  weightUnit     WeightUnit     @map("weight_unit")
  length         Decimal        @db.Decimal(12, 3)
  width          Decimal        @db.Decimal(12, 3)
  height         Decimal        @db.Decimal(12, 3)
  dimensionUnit  DimensionUnit  @map("dimension_unit")
  trackingNumber String?        @map("tracking_number")
  metadata       Json?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@unique([storeId, packageNumber])
  @@index([storeId])
  @@index([shipmentId])
  @@index([storeId, shipmentId])
  @@map("shipment_packages")
}

/// Append-only shipment tracking timeline entry.
model ShipmentTrackingEvent {
  id             String                    @id @default(uuid()) @db.Uuid
  shipmentId     String                    @map("shipment_id") @db.Uuid
  shipment       Shipment                  @relation(fields: [shipmentId], references: [id], onDelete: Restrict)
  storeId        String                    @map("store_id") @db.Uuid
  store          Store                     @relation(fields: [storeId], references: [id], onDelete: Restrict)
  statusSnapshot ShipmentStatus            @map("status_snapshot")
  eventType      ShipmentTrackingEventType @map("event_type")
  description    String
  location       String?
  metadata       Json?
  createdAt      DateTime                  @default(now()) @map("created_at")

  @@index([shipmentId])
  @@index([storeId])
  @@index([storeId, shipmentId])
  @@index([createdAt])
  @@map("shipment_tracking_events")
}

/// Store-scoped shipping zone grouping countries for rate configuration.
model ShippingZone {
  id              String             @id @default(uuid()) @db.Uuid
  storeId         String             @map("store_id") @db.Uuid
  store           Store              @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name            String
  countries       String[]
  status          ShippingZoneStatus @default(inactive)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  deletedAt       DateTime?          @map("deleted_at")
  shippingMethods ShippingMethod[]
  orderAppliedShippingMethods OrderAppliedShippingMethod[]

  @@index([storeId])
  @@index([status])
  @@index([storeId, status])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("shipping_zones")
}

/// Store-scoped flat-rate shipping method linked to a shipping zone.
model ShippingMethod {
  id             String               @id @default(uuid()) @db.Uuid
  storeId        String               @map("store_id") @db.Uuid
  store          Store                @relation(fields: [storeId], references: [id], onDelete: Restrict)
  shippingZoneId String               @map("shipping_zone_id") @db.Uuid
  shippingZone   ShippingZone         @relation(fields: [shippingZoneId], references: [id], onDelete: Restrict)
  name           String
  description    String?
  carrier        ShipmentCarrier
  flatRate       Decimal              @map("flat_rate") @db.Decimal(12, 2)
  currency       String               @db.Char(3)
  status         ShippingMethodStatus @default(inactive)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  deletedAt      DateTime?            @map("deleted_at")
  orderAppliedShippingMethods OrderAppliedShippingMethod[]

  @@index([storeId])
  @@index([shippingZoneId])
  @@index([storeId, shippingZoneId])
  @@index([status])
  @@index([storeId, status])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("shipping_methods")
}
