// CommerceFlow production schema — Identity and Organization domains.
// User/Session fields align with @commerceflow/types contracts.
// Organization models are persistence-only until shared contracts are introduced.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Mirrors UserRole from @commerceflow/types — do not add values without updating shared contracts.
enum UserRole {
  customer
  staff
  admin
  super_admin
}

enum SessionStatus {
  active
  revoked
  expired
}

enum StoreRole {
  owner
  manager
  staff
}

/// Mirrors ProductStatus from @commerceflow/types.
enum ProductStatus {
  draft
  active
  archived
}

/// Mirrors StockMovementReason from @commerceflow/types.
enum StockMovementReason {
  initial
  manual_adjustment
  sale_reserved_ready
}

/// Persists User contract fields plus passwordHash (API-internal).
model User {
  id              String        @id @default(uuid()) @db.Uuid
  email           String        @unique
  emailVerified   Boolean       @default(false) @map("email_verified")
  firstName       String        @map("first_name")
  lastName        String        @map("last_name")
  role            UserRole      @default(customer)
  passwordHash    String        @map("password_hash")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")
  sessions        Session[]
  storeMemberships StoreMember[]

  @@index([deletedAt])
  @@map("users")
}

/// Persists Session contract fields plus refreshTokenId and status (API-internal).
model Session {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         SessionStatus @default(active)
  expiresAt      DateTime      @map("expires_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  lastActiveAt   DateTime      @map("last_active_at")
  ipAddress      String?       @map("ip_address")
  userAgent      String?       @map("user_agent")
  refreshTokenId String        @map("refresh_token_id")

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("sessions")
}

/// Tenant boundary for multi-store commerce operations.
model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  stores    Store[]

  @@index([deletedAt])
  @@map("organizations")
}

/// Physical or logical storefront belonging to an organization.
model Store {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  name           String
  slug           String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  members        StoreMember[]
  brands         Brand[]
  categories     Category[]
  products       Product[]
  productVariants ProductVariant[]
  inventoryItems InventoryItem[]
  stockMovements StockMovement[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("stores")
}

/// Links a user to a store with a store-scoped role.
model StoreMember {
  id        String     @id @default(uuid()) @db.Uuid
  storeId   String     @map("store_id") @db.Uuid
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId    String     @map("user_id") @db.Uuid
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      StoreRole
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")

  @@unique([storeId, userId])
  @@index([userId])
  @@index([deletedAt])
  @@map("store_members")
}

/// Product brand used for catalog merchandising.
model Brand {
  id          String    @id @default(uuid()) @db.Uuid
  storeId     String    @map("store_id") @db.Uuid
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name        String
  slug        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  products    Product[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("brands")
}

/// Product category within the catalog hierarchy.
model Category {
  id          String     @id @default(uuid()) @db.Uuid
  storeId     String     @map("store_id") @db.Uuid
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name        String
  slug        String
  description String?
  parentId    String?    @map("parent_id") @db.Uuid
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")
  products    Product[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([parentId])
  @@index([storeId, parentId])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("categories")
}

/// Catalog product with one or more purchasable variants.
model Product {
  id          String           @id @default(uuid()) @db.Uuid
  storeId     String           @map("store_id") @db.Uuid
  store       Store            @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name        String
  slug        String
  description String?
  status      ProductStatus    @default(draft)
  categoryId  String           @map("category_id") @db.Uuid
  category    Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brandId     String?          @map("brand_id") @db.Uuid
  brand       Brand?           @relation(fields: [brandId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  variants    ProductVariant[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([storeId, categoryId])
  @@index([storeId, status])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("products")
}

/// Purchasable SKU belonging to a product.
model ProductVariant {
  id         String   @id @default(uuid()) @db.Uuid
  storeId    String   @map("store_id") @db.Uuid
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  productId  String   @map("product_id") @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku        String
  name       String
  price      Decimal  @db.Decimal(12, 2)
  currency   String   @db.Char(3)
  attributes Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  inventoryItem InventoryItem?

  @@unique([storeId, sku])
  @@index([storeId])
  @@index([productId])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("product_variants")
}

/// Current on-hand stock for a product variant within a store.
model InventoryItem {
  id               String          @id @default(uuid()) @db.Uuid
  storeId          String          @map("store_id") @db.Uuid
  store            Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  productVariantId String          @unique @map("product_variant_id") @db.Uuid
  productVariant   ProductVariant  @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  quantityOnHand   Int             @map("quantity_on_hand")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")
  stockMovements   StockMovement[]

  @@unique([storeId, productVariantId])
  @@index([storeId])
  @@index([deletedAt])
  @@index([storeId, deletedAt])
  @@map("inventory_items")
}

/// Immutable ledger entry for an inventory quantity change.
model StockMovement {
  id               String              @id @default(uuid()) @db.Uuid
  storeId          String              @map("store_id") @db.Uuid
  store            Store               @relation(fields: [storeId], references: [id], onDelete: Restrict)
  inventoryItemId  String              @map("inventory_item_id") @db.Uuid
  inventoryItem    InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  productVariantId String              @map("product_variant_id") @db.Uuid
  quantityChange   Int                 @map("quantity_change")
  quantityAfter    Int                 @map("quantity_after")
  reason           StockMovementReason
  createdAt        DateTime            @default(now()) @map("created_at")

  @@index([storeId])
  @@index([inventoryItemId])
  @@index([productVariantId])
  @@index([storeId, inventoryItemId])
  @@index([storeId, productVariantId])
  @@index([createdAt])
  @@map("stock_movements")
}
