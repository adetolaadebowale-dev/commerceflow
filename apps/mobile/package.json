{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start --dev-client --port 8081",
    "start": "expo start --port 8081",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8081",
    "lint": "eslint app/ features/ components/ providers/ services/ lib/ theme/ hooks/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "expo export --platform web --output-dir dist",
    "clean": "node -e \"require('fs').rmSync('.expo',{recursive:true,force:true}); require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@commerceflow/api-client": "workspace:*",
    "@commerceflow/types": "workspace:*",
    "@commerceflow/utils": "workspace:*",
    "@commerceflow/validation": "workspace:*",
    "@expo/log-box": "^57.0.0",
    "@expo/metro-runtime": "~57.0.6",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.4.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.90.2",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "~57.0.5",
    "expo-font": "~57.0.0",
    "expo-image": "~57.0.1",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-secure-store": "^57.0.0",
    "expo-splash-screen": "^57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.1",
    "nativewind": "^4.1.23",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.65.0",
    "react-native": "0.86.0",
    "react-native-css-interop": "^0.2.6",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "whatwg-fetch": "^3.6.20",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@commerceflow/config": "workspace:*",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.2",
    "eslint": "^8.57.1",
    "prettier-plugin-tailwindcss": "0.5.11",
    "react-test-renderer": "19.2.3",
    "tailwindcss": "3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
