# CommerceFlow Mobile — environment template
# Copy to `.env.local` for machine-specific overrides (gitignored).
#
# Physical devices / Emulators that cannot reach "localhost":
# use your machine's LAN IP, e.g. http://192.168.1.10:3000
#
# Expo inlines EXPO_PUBLIC_* at bundle time (Metro / EAS Build).

EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
