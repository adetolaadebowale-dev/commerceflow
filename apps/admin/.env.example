# Admin Dashboard local environment
# Copy to apps/admin/.env.local

# Backend API base URL (must match a running apps/api process)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Seeded development store id from `pnpm --filter api db:seed`
NEXT_PUBLIC_DEFAULT_STORE_ID=11111111-1111-1111-1111-111111111111
